---
layout: null
sitemap: false
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
{% for post in site.posts %}
  <url>
    <loc>{{ site.url }}{{ post.url | xml_escape }}</loc>
    <lastmod>{{ post.date | date_to_xmlschema }}</lastmod>
  </url>
{% endfor %}
{% for page in site.pages %}
  {% unless page.sitemap == false %}
    {% assign last_char = page.url | slice: -1 %}
    {% if last_char == '/' or page.url contains '.html' %}
  <url>
    <loc>{{ site.url }}{{ page.url | xml_escape }}</loc>
    {% if page.last_modified_at %}<lastmod>{{ page.last_modified_at | date_to_xmlschema }}</lastmod>{% endif %}
  </url>
    {% endif %}
  {% endunless %}
{% endfor %}
</urlset>
